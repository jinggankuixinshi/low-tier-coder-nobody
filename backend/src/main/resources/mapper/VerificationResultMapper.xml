<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.evaluation.mapper.VerificationResultMapper">

    <delete id="deleteBySubmissionId">
        DELETE FROM verification_result WHERE submission_id = #{submissionId}
    </delete>

    <select id="selectBySubmissionId" resultType="com.example.evaluation.entity.VerificationResult">
        SELECT * FROM verification_result
        WHERE submission_id = #{submissionId}
        ORDER BY check_type ASC
    </select>

</mapper>
