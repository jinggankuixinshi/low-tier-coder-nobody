<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.evaluation.mapper.EvaluationTemplateMapper">

    <select id="selectByTaskId" resultType="com.example.evaluation.entity.EvaluationTemplate">
        SELECT * FROM evaluation_template
        WHERE deleted = 0
        <if test="taskId != null">
            AND task_id = #{taskId}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
